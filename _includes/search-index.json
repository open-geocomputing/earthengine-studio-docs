[
  {% assign localized_docs = site.docs | where: "lang", page.lang | sort: "order" %}
  {% for item in localized_docs %}
  {
    "title": {{ item.title | jsonify }},
    "url": {{ item.url | relative_url | jsonify }},
    "description": {{ item.description | jsonify }},
    "keywords": {{ item.keywords | join: " " | jsonify }},
    "content": {{ item.content | markdownify | strip_html | normalize_whitespace | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
